{
  "port": {
    "isPhysical": {
      "description": "(boolean) 是否为物理端口。用于区分物理口、Eth-Trunk、子接口。",
      "change_type": "added"
    },
    "portType": {
      "description": "(enum) 端口类型。取值：Physical, Eth-Trunk, Sub-interface, Loopback。",
      "change_type": "added"
    },
    "activeMemberCount": {
      "description": "(integer) Eth-Trunk 当前处于 Up 状态的成员口数量。",
      "change_type": "added"
    },
    "currentAlarms": {
      "description": "(array) 当前端口挂载的活动告警名称列表。无告警返回空数组。",
      "change_type": "added"
    },
    "isSameFecMode": {
      "description": "(boolean) 两端端口是否为相同的FEC模式"
    },
    "isSamePortWorkMode": {
      "description": "(boolean) 两端端口是否为相同的工作模式"
    },
    "portAdminStatus": {
      "description": "(string) 端口管理状态，取值 up|down, 无值返回空字符串"
    },
    "portOperateStatus": {
      "description": "(string) 端口运行状态，取值 up|down, 无值返回空字符串"
    },
    "portOpticalPowerStatus": {
      "description": "(string) 状态枚举，normal/abnormal。逻辑口必须返回 NOT_APPLICABLE。",
      "original_description": "(string) 状态枚举，normal代表端口的收发光都正常，abnormal代表收光或发光至少有一个状态不为正常",
      "change_type": "modified"
    },
    "inPower": {
      "description": "(number) 输入光功率。逻辑口返回 null。",
      "original_description": "(number) 输入光功率",
      "change_type": "modified"
    },
    "inPowerStatus": {
      "description": "(string) 输入光功率状态：强光、弱光、正常、无光。逻辑口返回 null。",
      "original_description": "(string) 输入光功率状态，返回值包括：强光、弱光、正常、无光",
      "change_type": "modified"
    },
    "outPower": {
      "description": "(number) 输出光功率。逻辑口返回 null。",
      "original_description": "(number) 输出光功率",
      "change_type": "modified"
    },
    "outPowerStatus": {
      "description": "(string) 输出光功率状态：强光、弱光、正常、无光。逻辑口返回 null。",
      "original_description": "(string) 输出光功率状态，返回值包括：强光、弱光、正常、无光",
      "change_type": "modified"
    },
    "portOpticalPowerErrCode": {
      "description": "(enum) 端口光功率错误码：NONE, DEV_OFFLINE, BOARD_STATUS_ABNORMAL",
      "original_description": "(enum(string)) 端口光功率错误码，NONE：无报错，DEV_OFFLINE：端口所属网元离线，BOARD_STATUS_ABNORMAL：端口所属单板状态异常",
      "change_type": "modified"
    },
    "portOpticalPowerDetails.portOpticalPowerInfo.inPower": {
      "description": "(number) 输入光功率"
    },
    "portOpticalPowerDetails.portOpticalPowerInfo.minInPower": {
      "description": "(number) 输入下门限"
    },
    "portOpticalPowerDetails.portOpticalPowerInfo.maxInPower": {
      "description": "(number) 输入上门限"
    },
    "portOpticalPowerDetails.portOpticalPowerInfo.outPower": {
      "description": "(number) 输出光功率"
    },
    "portOpticalPowerDetails.portOpticalPowerInfo.minOutPower": {
      "description": "(number) 输出下门限"
