      "description": "(boolean) 对端网元是否纳管。若为false，remotePort状态应返回Unknown。",
      "original_description": "(boolean) 对端网元是否纳管（是否为传输侧网元）",
      "change_type": "modified"
    },
    "isNormal": {
      "description": "(boolean) 网络是否正常"
    },
    "isOpticalNormal": {
      "description": "(boolean) 光功率是否正常"
