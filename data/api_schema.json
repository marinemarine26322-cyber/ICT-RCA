  "link": {
    "localPortFaultType": {
      "description": "(string) 源端端口故障等级：Critical, Major, Minor, Unknown, Normal。"
    },
    "localPortDetailInfo": {
      "description": "(string) 源端端口故障详细信息"
    },
    "remotePortFaultType": {
      "description": "(string) 对端端口故障等级。若对端未纳管(isManagedPE=false)，必须返回 Unknown。",
      "original_description": "(string) 对端端口故障等级，可能的取值为：Critical、Major、Minor、Unknown、Normal，其中Unknown和Normal代表没有明确的风险，其他取值代表存在脏污隐患",
      "change_type": "modified"
    },
    "remotePortDetailInfo": {
      "description": "(string) 对端故障详情。若对端未纳管，返回 '对端设备未纳管/不在拓扑范围内'。",
      "original_description": "(string) 对端端口故障详细信息，当故障等级不为Unknown和Normal时，作为诊断结论返回",
      "change_type": "modified"
    }
  },
